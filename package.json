{
  "name": "probox_telegrambot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "clean": "rimraf dist",
    "build": "npm run clean && node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc && copyfiles -u 0 \"src/**/*.{ftl,sql}\" \"src/uploads/**/*\" dist/",
    "start": "node dist/src/server.js",
    "db:migrate": "node -r ts-node/register ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:latest",
    "db:status": "node -r ts-node/register ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:list",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "debug:contracts": "ts-node src/scripts/debug-contracts.ts",
    "check:gemini": "ts-node src/scripts/check-gemini-key.ts",
    "debug:payment-reminder": "ts-node src/scripts/test-payment-reminder.ts",
    "run:payment-reminder": "ts-node src/scripts/run-payment-reminder.ts",
    "repair:payment-on-time-coupons": "ts-node src/scripts/repair-payment-on-time-coupons.ts",
    "test:purchase-pdf": "ts-node src/scripts/test-purchase-pdf.ts",
    "test:payment-reminder": "node --require ts-node/register --test --test-force-exit src/services/payment/payment-reminder.service.spec.ts",
    "test:faq-routing": "node --require ts-node/register --test src/services/faq/faq-routing.service.spec.ts src/services/faq/faq-ai.service.spec.ts src/services/faq/faq.service.spec.ts src/utils/faq/faq-routing-score.util.spec.ts",
    "compare:current": "ts-node -P passport_comparison/tsconfig.json passport_comparison/runner/run-current.ts",
    "compare:python": "ts-node -P passport_comparison/tsconfig.json passport_comparison/runner/run-python.ts",
    "compare:report": "ts-node -P passport_comparison/tsconfig.json passport_comparison/runner/run-comparison.ts",
    "compare:test": "node --require ts-node/register --test passport_comparison/**/*.spec.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/i18n": "^1.1.2",
    "@grammyjs/storage-redis": "^2.5.1",
    "@gutenye/ocr-node": "^1.4.8",
    "@sap/hana-client": "^2.27.19",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "fastify": "^4.29.1",
    "form-data": "^4.0.5",
    "grammy": "^1.39.3",
    "ioredis": "^5.9.2",
    "jsqr": "^1.4.0",
    "knex": "^3.1.0",
    "minio": "^8.0.6",
    "node-cron": "^4.2.1",
    "pg": "^8.17.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/form-data": "^2.2.1",
    "@types/node": "^25.0.9",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0"
  }
}
